% Store part title for running head (left-center even page)
\newcommand{\currentparttitle}{\subtitle} % default before first \part
\let\oldpart\part
\RenewDocumentCommand{\part}{ o m }{%
  \gdef\currentparttitle{#2}%
  \IfNoValueTF{#1}{\oldpart{#2}}{\oldpart[#1]{#2}}%
}

% With the book class, \titleformat{\part} runs \titleclass{\part}{page}, so \part uses
% \ttl@page@i (not \ttl@part@i). titlesec's \ttl@labelling overwrites \ttl@savewrite with
% \ttl@write{#1}{#2} (optional short title), duplicating "Part I" in the .toc; restore #3 after it.
\makeatletter
\def\ttl@page@i#1[#2]#3{%
  \gdef\ttl@savemark{\csname#1mark\endcsname{#3}}%
  \ifx\ttl@notocparts\@undefined
    \def\ttl@savewrite{\ttl@write{#1}{#3}}%
  \else
    \let\ttl@savewrite\@empty
  \fi
  \def\ttl@savetitle{#3}%
  \ttl@labelling{#1}{#2}%
  \ifx\ttl@notocparts\@undefined
    \def\ttl@savewrite{\ttl@write{#1}{#3}}%
  \fi
  \ttl@startargs\ttl@page@ii{#1}{#3}}
\makeatother

