% Call \tocbackmatterdivider once after \backmatter (before Glossary): inserts space and a
% small flourish line in the .toc only, so the last Part is visually separated from back matter.
% (Macro name must not contain @: .aux is read before @ is a letter.)
\newcommand{\tocbackmatterdivider}{%
  \addtocontents{toc}{\protect\tocbackmatterdividerprint}%
}
\newcommand{\tocbackmatterdividerprint}{%
  \nobreak
  \vskip 1em plus 2pt minus 2pt
  \begingroup
  \parindent \z@
  \normalfont\normalsize
  \noindent\rule{2cm}{1pt}
  \par
  \endgroup
  \nobreak
  \vskip 0.75em plus 2pt minus 2pt
}

