% TOC
\usepackage[titles]{tocloft} % Make the part *number* print as "Part I" 
\renewcommand{\cftpartpresnum}{\partname~} % "Part " 

% \renewcommand{\cftchapfont}{\large\itshape} 
% \renewcommand{\cftchappagefont}{\normalfont} 
% \renewcommand{\numberline}[1]{}
\renewcommand{\cftpartaftersnum}{} % nothing after the Roman numeral 
\renewcommand{\cftchapfont}{\large\itshape}
\renewcommand{\cftchappagefont}{\normalfont}
% (Do not redefine \numberline to {} — that hides chapter/section numbers in the TOC.)

% PART entries (bigger / more prominent)
\renewcommand{\cftpartfont}{\Large\scshape}
\renewcommand{\cftpartpagefont}{\Large\normalfont}

% CHAPTER entries (smaller / subordinate)
\renewcommand{\cftchapfont}{\normalsize}      % or \small\itshape
\renewcommand{\cftchappagefont}{\normalsize\normalfont}
% Widen the number column so Roman numerals (e.g. VIII, XII) don't crowd the title
\setlength{\cftchapnumwidth}{2.5em}
% Tighten vertical gap between chapter entries (default 1.0em) so the TOC fits one page
\setlength{\cftbeforechapskip}{0.5em}

% Call \tocbackmatterdivider once after \backmatter (before Glossary): inserts space and a
% small flourish line in the .toc only, so the last Part is visually separated from back matter.
% (Macro name must not contain @: .aux is read before @ is a letter.)
\newcommand{\tocbackmatterdivider}{%
  \addtocontents{toc}{\protect\tocbackmatterdividerprint}%
}
\newcommand{\tocbackmatterdividerprint}{%
  \nobreak
  \vskip 1em plus 2pt minus 2pt
  \begingroup
  \parindent \z@
  \normalfont\normalsize
  \noindent\rule{2cm}{1pt}
  \par
  \endgroup
  \nobreak
  \vskip 0.75em plus 2pt minus 2pt
}

