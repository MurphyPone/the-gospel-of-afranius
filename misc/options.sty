% Holds the optional "Book ..." line for the next chapter (empty by default)
\newcommand{\chapterbook}{}

\titleformat{\chapter}[display]
  {\normalfont}
  {\centering{\fontsize{72}{80}\selectfont\thechapter}\\}
  {0.5em}
  {\centering\huge}
  [
    \if\relax\detokenize{\chapterbook}\relax
