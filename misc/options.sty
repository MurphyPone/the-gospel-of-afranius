% XeLaTeX: load fontspec first for Unicode support
\usepackage{fontspec}

% Font for old English / long s (U+017F); Libertine has the glyph, Merriweather does not.
% Try filename first (from libertine package in TeX Live); else fall back to default so doc compiles.
\IfFontExistsTF{LinLibertine_R.otf}{%
  \newfontfamily\oldenglishfont{LinLibertine_R.otf}%
}{%
  \IfFontExistsTF{LinLibertine_O.otf}{%
    \newfontfamily\oldenglishfont{LinLibertine_O.otf}%
  }{%
    \let\oldenglishfont\normalfont
  }%
}

% Typewriter font for the Afranius letterhead (Courier-like). Prefer Courier New
% (cleaner outline), then Courier, else fall back to the default monospace family.
\IfFontExistsTF{Courier New}{%
  \newfontfamily\letterheadfont{Courier New}%
}{%
  \IfFontExistsTF{Courier}{%
    \newfontfamily\letterheadfont{Courier}%
  }{%
    \let\letterheadfont\ttfamily
  }%
}

