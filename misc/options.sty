\renewcommand{\thechapter}{\Roman{chapter}}
\renewcommand{\chaptermark}[1]{\markboth{#1}{}}

% Part and Chapter re-definitions
\usepackage{adforn}
\usepackage{xparse}

% Holds the optional "Book ..." line for the next chapter (empty by default)
\newcommand{\chapterbook}{}

\titleformat{\chapter}[display]
  {\normalfont}
  {\centering{\fontsize{72}{80}\selectfont\thechapter}\\}
  {0.5em}
  {\centering\huge}
  [
    \if\relax\detokenize{\chapterbook}\relax
    \else 
      \vspace{0.5em}
      \centering{\normalfont\Large \chapterbook}
    \fi
  ]

% Space above chapter block (smaller = title higher on the page).
% change 0.75em 1.25em or higher to move chapter title lower on the page
\titlespacing*{\chapter}{0pt}{0.75em}{2em}

% Optional chapter on a specific book.
% Unstarred: \chapter[toc]{Title} or \chapter[toc][Subtitle]{Title} -> numbered.
% Starred:   \chapter*{Title}      or \chapter*[Subtitle]{Title}    -> unnumbered,
%            no Roman numeral, but the same centered title + optional subtitle line.
\let\oldchapter\chapter
\RenewDocumentCommand{\chapter}{ s O{} O{} m }{%
  \IfBooleanTF{#1}
    {% starred: unnumbered chapter; first optional arg is the subtitle.
      % \chapter* does not run \chaptermark or write to the .toc, so do both by hand.
      \gdef\chapterbook{#2}%
      \oldchapter*{#4}%
      \chaptermark{#4}%
      \addcontentsline{toc}{chapter}{#4}%
      \gdef\chapterbook{}%
    }
    {% unstarred: original behaviour (#2 = toc short title, #3 = "Book ..." subtitle)
      \gdef\chapterbook{#3}%
      \if\relax\detokenize{#2}\relax
        \oldchapter{#4}%
      \else
        \oldchapter[#2]{#4}%
      \fi
      \gdef\chapterbook{}% reset so it doesn't leak to the next chapter
    }%
}

\titleformat{\part}[display]
  {\centering}                    % overall alignment
  {\fontsize{48}{56}\selectfont
  Part \thepart}                  % BIG "Part I"
  {2em}                           % space between label and title
  {\Huge\itshape}                 % title style
  [\vspace{1em}\adfdoublesharpflourishleft\quad\adfast{9}\quad\adfdoublesharpflourishright] 

% Store part title for running head (left-center even page)
\newcommand{\currentparttitle}{\subtitle} % default before first \part
\let\oldpart\part
\RenewDocumentCommand{\part}{ o m }{%
  \gdef\currentparttitle{#2}%
  \IfNoValueTF{#1}{\oldpart{#2}}{\oldpart[#1]{#2}}%
}

% With the book class, \titleformat{\part} runs \titleclass{\part}{page}, so \part uses
% \ttl@page@i (not \ttl@part@i). titlesec's \ttl@labelling overwrites \ttl@savewrite with
% \ttl@write{#1}{#2} (optional short title), duplicating "Part I" in the .toc; restore #3 after it.
\makeatletter
\def\ttl@page@i#1[#2]#3{%
  \gdef\ttl@savemark{\csname#1mark\endcsname{#3}}%
  \ifx\ttl@notocparts\@undefined
    \def\ttl@savewrite{\ttl@write{#1}{#3}}%
  \else
    \let\ttl@savewrite\@empty
  \fi
  \def\ttl@savetitle{#3}%
  \ttl@labelling{#1}{#2}%
  \ifx\ttl@notocparts\@undefined
    \def\ttl@savewrite{\ttl@write{#1}{#3}}%
  \fi
  \ttl@startargs\ttl@page@ii{#1}{#3}}
\makeatother

