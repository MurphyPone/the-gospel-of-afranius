      \vspace{0.5em}
      \centering{\normalfont\Large \chapterbook}
    \fi
  ]

% Space above chapter block (smaller = title higher on the page).
% change 0.75em 1.25em or higher to move chapter title lower on the page
\titlespacing*{\chapter}{0pt}{0.75em}{2em}

% Optional chapter on a specific book
\let\oldchapter\chapter
\RenewDocumentCommand{\chapter}{ O{} O{} m }{%
  \gdef\chapterbook{#2}%
  \IfNoValueTF{#1}
    {\oldchapter{#3}}
    {%
      % If user left the first optional arg empty, treat it as "not provided"
      \if\relax\detokenize{#1}\relax
        \oldchapter{#3}%
      \else
        \oldchapter[#1]{#3}%
      \fi
    }%
  \gdef\chapterbook{}% reset so it doesn't leak to the next chapter
}

% --- Chapter opener: optional verso plate + recto \chapter (twoside spreads) ---
% The book class is often used with openany, so \chapter does not guarantee a recto
% opening. Call \chapteropener (with or without an image) immediately before \chapter
% when you want the chapter title to begin on a right-hand (odd) page. If an image path
% is given, it is set alone on the preceding verso (even) page with the attribution below.
% The attribution is a single braced argument: avoid ``\cmd{}'' before the closing ``}''
% (use ``\PL '' or ``\PL\ '' instead of ``\PL{}''), or wrap the whole line in an extra
% pair of braces: \chapteropener[fig]{{Text \PL{} here.}}
% For a recto chapter with no plate, use \chapterrectoonly instead of \chapteropener with
% an empty optional (the latter ignores the attribution argument).
\makeatletter
\newcommand{\ttlchapterforcerecto}{%
  \clearpage
  \if@twoside
    \ifodd\c@page
    \else
      \null\thispagestyle{empty}\newpage
    \fi
  \fi
}
\newcommand{\ttlchapterensureverso}{%
  \clearpage
  \if@twoside
    \ifodd\c@page
      \null\thispagestyle{empty}\newpage
    \fi
  \fi
}
\makeatother
\newcommand{\chapterrectoonly}{\ttlchapterforcerecto}
\NewDocumentCommand{\chapteropener}{ O{} m }{%
  \if\relax\detokenize{#1}\relax
    \ttlchapterforcerecto
  \else
    \ttlchapterensureverso
    \thispagestyle{empty}%
    \enlargethispage{\baselineskip}%
    \vspace*{\stretch{1}}%
    \begin{center}
      \includegraphics[width=\linewidth,height=0.72\textheight,keepaspectratio]{#1}%
    \end{center}%
    \vspace{\stretch{1.5}}%
    \if\relax\detokenize{#2}\relax
    \else
      \begin{minipage}[t]{\linewidth}
        \footnotesize\itshape\raggedright
        \noindent #2\par
      \end{minipage}%
    \fi
    \vspace*{\stretch{1}}%
    \clearpage
    \ttlchapterforcerecto
  \fi
}

